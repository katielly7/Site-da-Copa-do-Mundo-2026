<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Copa do Mundo 2026</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family: Arial, Helvetica, sans-serif;
    }

    body{
      background:#0b1020;
      color:white;
      padding:20px;
    }

    h1{
      text-align:center;
      margin-bottom:30px;
      color:#00e1ff;
    }

    h2{
      margin-top:40px;
      margin-bottom:15px;
      color:#ffd700;
      border-left:5px solid #00e1ff;
      padding-left:10px;
    }

    .grupo{
      background:#141b34;
      padding:20px;
      border-radius:12px;
      margin-bottom:25px;
      box-shadow:0 0 10px rgba(0,0,0,0.5);
    }

    table{
      width:100%;
      border-collapse:collapse;
      margin-top:15px;
    }

    th{
      background:#00e1ff;
      color:#000;
      padding:12px;
    }

    td{
      border:1px solid #2b355f;
      padding:10px;
      text-align:center;
    }

    tr:nth-child(even){
      background:#1c2647;
    }

    .fase{
      background:#141b34;
      padding:20px;
      border-radius:12px;
      margin-top:25px;
    }

    .jogo{
      background:#1d274d;
      padding:15px;
      margin:10px 0;
      border-radius:10px;
    }

    .time{
      display:flex;
      align-items:center;
      gap:10px;
      justify-content:center;
    }

    .time img{
      width:35px;
      height:35px;
      border-radius:50%;
      object-fit:cover;
    }

    .eliminatorias{
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(250px,1fr));
      gap:20px;
    }

    .card{
      background:#1b2444;
      padding:15px;
      border-radius:12px;
    }

    .escalacao{
      display:grid;
      grid-template-columns:repeat(auto-fit, minmax(150px,1fr));
      gap:15px;
      margin-top:20px;
    }

    .jogador{
      background:#1b2444;
      padding:15px;
      border-radius:10px;
      text-align:center;
    }

    .jogador img{
      width:80px;
      height:80px;
      border-radius:50%;
      object-fit:cover;
      margin-bottom:10px;
    }

    footer{
      margin-top:40px;
      text-align:center;
      color:#aaa;
    }

  </style>
</head>
<body>

  <h1>🏆 Copa do Mundo 2026</h1>

  <!-- FASE DE GRUPOS -->
  <h2>Fase de Grupos</h2>

  <div class="grupo">
    <h3>Grupo A</h3>

    <table>
      <tr>
        <th>Data</th>
        <th>Hora</th>
        <th>Jogo</th>
        <th>Estádio</th>
      </tr>

      <tr>
        <td>12/06/2026</td>
        <td>16:00</td>
        <td>
          Brasil 🇧🇷 vs Argentina 🇦🇷
        </td>
        <td>Estádio Central</td>
      </tr>

      <tr>
        <td>15/06/2026</td>
        <td>18:00</td>
        <td>
          França 🇫🇷 vs Alemanha 🇩🇪
        </td>
        <td>National Arena</td>
      </tr>

      <tr>
        <td>18/06/2026</td>
        <td>20:00</td>
        <td>
          Brasil 🇧🇷 vs França 🇫🇷
        </td>
        <td>World Stadium</td>
      </tr>
    </table>
  </div>

  <!-- ELIMINATÓRIAS -->
  <h2>Eliminatórias</h2>

  <div class="eliminatorias">

    <div class="card">
      <h3>Oitavas de Final</h3>

      <div class="jogo">
        🇧🇷 Brasil vs 🇺🇸 EUA<br>
        📅 28/06/2026<br>
        ⏰ 17:00
      </div>

      <div class="jogo">
        🇦🇷 Argentina vs 🇫🇷 França<br>
        📅 29/06/2026<br>
        ⏰ 20:00
      </div>
    </div>

    <div class="card">
      <h3>Quartas de Final</h3>

      <div class="jogo">
        🇧🇷 Brasil vs 🇦🇷 Argentina<br>
        📅 03/07/2026<br>
        ⏰ 18:00
      </div>
    </div>

    <div class="card">
      <h3>Semifinal</h3>

      <div class="jogo">
        🇧🇷 Brasil vs 🇪🇸 Espanha<br>
        📅 08/07/2026<br>
        ⏰ 21:00
      </div>
    </div>

    <div class="card">
      <h3>Final</h3>

      <div class="jogo">
        🇧🇷 Brasil vs 🇫🇷 França<br>
        📅 12/07/2026<br>
        ⏰ 20:00
      </div>
    </div>

  </div>

  <!-- ESCALAÇÃO -->
  <h2>Escalação do Brasil</h2>

  <div class="escalacao">

    <div class="jogador">
      <img src="https://i.imgur.com/4AiXzf8.jpeg" alt="Jogador">
      <h4>Alisson</h4>
      <p>Goleiro</p>
    </div>

    <div class="jogador">
      <img src="https://i.imgur.com/4AiXzf8.jpeg" alt="Jogador">
      <h4>Marquinhos</h4>
      <p>Zagueiro</p>
    </div>

    <div class="jogador">
      <img src="https://i.imgur.com/4AiXzf8.jpeg" alt="Jogador">
      <h4>Vinícius Jr</h4>
      <p>Atacante</p>
    </div>

    <div class="jogador">
      <img src="https://i.imgur.com/4AiXzf8.jpeg" alt="Jogador">
      <h4>Rodrygo</h4>
      <p>Atacante</p>
    </div>

  </div>

  <footer>
    © 2026 - Tabela Copa do Mundo
  </footer>

</body>
</html>
